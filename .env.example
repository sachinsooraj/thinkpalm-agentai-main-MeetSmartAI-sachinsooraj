# MeetSmart AI — Environment Variables
# Copy this file to .env and fill in your values

# ── Gemini LLM ──────────────────────────────────────────────
# Get a free key at https://ai.google.dev
# Leave blank to use rule-based fallback (still fully functional)
GEMINI_API_KEY=

# ── Email / SMTP ─────────────────────────────────────────────
# Set SMTP_MODE=mock   → logs emails to console (no setup needed, great for demos)
# Set SMTP_MODE=gmail  → sends real emails via Gmail
SMTP_MODE=mock

# Gmail settings (only needed when SMTP_MODE=gmail)
GMAIL_ADDRESS=your-email@gmail.com
# Generate an App Password at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your-16-char-app-password

# ── App Settings ──────────────────────────────────────────────
APP_NAME=MeetSmart AI
APP_HOST=localhost
API_PORT=8000
FRONTEND_PORT=5173

# Database path (relative to project root)
DATABASE_URL=sqlite:///./meetsmart.db

# Output folder for MoM docs
OUTPUTS_DIR=./outputs
